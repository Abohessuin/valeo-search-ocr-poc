PORT=3001
FRONTEND_ORIGIN=http://localhost:3002

# OCR provider selection.
# paddle is the local default. google is for production/cloud usage.
OCR_PROVIDER=paddle

# Local PaddleOCR FastAPI service.
PADDLE_OCR_URL=http://localhost:8000
PADDLE_OCR_TIMEOUT_MS=15000

# Google Cloud Vision. Uses Application Default Credentials when enabled.
# Do not commit credentials. Set ADC locally or in the deployment environment.
# OCR_PROVIDER=google
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
# GOOGLE_OCR_TIMEOUT_MS=15000
